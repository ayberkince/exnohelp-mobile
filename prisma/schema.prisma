// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- ENUMS (State Machines) ---
enum Role {
  CLIENT
  HELPER
  ADMIN
}

enum RequestStatus {
  OPEN
  MATCHED
  CANCELED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELED_BY_CLIENT
  CANCELED_BY_HELPER
  CANCELED_BY_PLATFORM
}

// Day 6: Financial State Machines
enum PaymentStatus {
  UNPAID
  AUTHORIZED
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PayoutStatus {
  NOT_READY
  PENDING
  PAID_OUT
  HELD
  REVERSED
}

enum RefundStatus {
  NONE
  REQUESTED
  UNDER_REVIEW
  APPROVED_FULL
  APPROVED_PARTIAL
  DENIED
  COMPLETED
}

// Day 7: Trust & Safety State Machines
enum ReportType {
  NO_SHOW
  SEVERE_LATENESS
  UNSAFE_BEHAVIOR
  HARASSMENT
  DISCRIMINATION
  PROHIBITED_SERVICE
  OFF_PLATFORM_PAYMENT
  FRAUD
  SUSPICIOUS_IDENTITY
  OTHER
}

enum ReportStatus {
  OPEN
  UNDER_REVIEW
  ACTION_TAKEN
  DISMISSED
  CLOSED
}

enum EnforcementLevel {
  NONE
  WARNING
  RESTRICTED
  SUSPENDED
  BANNED
}

// Day 8: Operator State Machines
enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_ACTION
}

// Day 9: Communication State Machines
enum NotificationType {
  BOOKING
  PAYMENT
  SAFETY
  ACCOUNT
  SYSTEM
}

// --- AUTHENTICATION MODELS (NextAuth) ---
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role?
  
  // Day 7: Platform enforcement
  enforcement   EnforcementLevel @default(NONE)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  clientProfile ClientProfile?
  helperProfile HelperProfile?

  // Day 7: Report Tracking
  reportsFiled   Report[] @relation("Reporter")
  reportsAgainst Report[] @relation("ReportedUser")

  // Day 9: Communication Tracking
  notifications  Notification[]

  // Day 10: Analytics & Telemetry
  analyticsEvents AnalyticsEvent[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// --- PLATFORM PROFILES ---
model ClientProfile {
  id                    String  @id @default(cuid())
  userId                String  @unique
  user                  User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  city                  String?
  district              String?
  emergencyContactName  String?
  emergencyContactPhone String?

  requests SupportRequest[]
  bookings Booking[]
}

model HelperProfile {
  id       String  @id @default(cuid())
  userId   String  @unique
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  city     String?
  district String?

  // Day 8: Verification Ops
  verificationStatus VerificationStatus @default(PENDING)
  adminNotes         String?            @db.Text

  bookings Booking[]
  payouts  Payout[] 
}

// --- MARKETPLACE ENGINE ---
model SupportRequest {
  id            String        @id @default(cuid())
  clientId      String
  client        ClientProfile @relation(fields: [clientId], references: [id])
  categorySlug  String
  title         String
  description   String?
  requestedDate DateTime
  city          String
  district      String
  status        RequestStatus @default(OPEN)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  booking Booking?
}

model Booking {
  id        String          @id @default(cuid())
  clientId  String
  client    ClientProfile   @relation(fields: [clientId], references: [id])
  helperId  String
  helper    HelperProfile   @relation(fields: [helperId], references: [id])
  requestId String?         @unique
  request   SupportRequest? @relation(fields: [requestId], references: [id])

  scheduledAt DateTime
  status      BookingStatus @default(PENDING)

  // Day 6: Pricing Logistics
  helperAmount Float @default(0.0)
  platformFee  Float @default(0.0)
  totalAmount  Float @default(0.0)

  // Day 6: Financial Links
  payment Payment?
  payout  Payout?

  // Day 7: Incident Tracking Links
  reports Report[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- DAY 6: FINANCIAL ENGINE ---
model Payment {
  id        String  @id @default(cuid())
  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [id])

  amount       Float
  status       PaymentStatus @default(UNPAID)
  refundStatus RefundStatus  @default(NONE)

  stripePaymentIntentId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payout {
  id        String        @id @default(cuid())
  bookingId String        @unique
  booking   Booking       @relation(fields: [bookingId], references: [id])
  helperId  String
  helper    HelperProfile @relation(fields: [helperId], references: [id])

  amount Float
  status PayoutStatus @default(NOT_READY)

  stripeTransferId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- DAY 7 & 8: TRUST, SAFETY & OPS ENGINE ---
model Report {
  id          String       @id @default(cuid())
  type        ReportType
  status      ReportStatus @default(OPEN)
  description String       @db.Text
  
  reporterId  String
  reporter    User         @relation("Reporter", fields: [reporterId], references: [id])
  
  reportedUserId String?
  reportedUser   User?     @relation("ReportedUser", fields: [reportedUserId], references: [id])
  
  bookingId   String?
  booking     Booking?     @relation(fields: [bookingId], references: [id])
  
  adminNotes  String?      @db.Text
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  adminActions AdminAction[]
}

model AdminAction {
  id          String   @id @default(cuid())
  reportId    String?
  report      Report?  @relation(fields: [reportId], references: [id])
  
  adminId     String   
  actionTaken String   
  notes       String?  @db.Text
  
  createdAt   DateTime @default(now())
}

// --- DAY 9: COMMUNICATION ENGINE ---
model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type      NotificationType
  title     String
  message   String           @db.Text
  isRead    Boolean          @default(false)
  link      String?          
  
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

// --- DAY 10: ANALYTICS & TELEMETRY ENGINE ---
model AnalyticsEvent {
  id          String   @id @default(cuid())
  eventName   String   
  
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userRole    String?  
  
  targetId    String?  
  properties  Json?    
  
  createdAt   DateTime @default(now())

  // Indexes to make graph generation fast!
  @@index([eventName])
  @@index([createdAt])
  @@index([userId])
}

model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      String   // "CLIENT" or "HELPER"
  district  String?
  interest  String?  // e.g., "Accompaniment", "Paperwork"
  createdAt DateTime @default(now())
}

model Feedback {
  id        String   @id @default(cuid())
  userId    String?
  role      String?  // CLIENT or HELPER
  category  String   // BUG, UI, TRUST, etc.
  text      String
  severity  String   @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  pageUrl   String?
  createdAt DateTime @default(now())
}
generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- USER & IDENTITY ---

model User {
  id               String         @id @default(cuid())
  email            String         @unique
  passwordHash     String?        
  role             UserRole       @default(CLIENT)
  firstName        String?
  lastName         String?
  profilePhotoUrl  String?
  isActive         Boolean        @default(true)
  isSuspended      Boolean        @default(false)
  suspensionReason String?
  
  // Relations
  clientProfile    ClientProfile?
  helperProfile    HelperProfile?
  sentMessages     Message[]
  reportsFiled     Report[]       @relation("Reporter")
  reportsAgainst   Report[]       @relation("ReportedUser")
  adminActions     AdminAction[]
  
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

enum UserRole {
  CLIENT
  HELPER
  ADMIN
}

// --- PROFILES ---

model ClientProfile {
  id                    String            @id @default(cuid())
  userId                String            @unique
  user                  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Day 4 Onboarding Fields
  emergencyContactName  String?
  emergencyContactPhone String?
  city                  String?           @default("Berlin")
  district              String?
  preferredLanguage     String?           @default("English")
  accessibilityNotes    String?
  
  // Relations
  requests              SupportRequest[]
  bookings              Booking[]
}

model HelperProfile {
  id                  String            @id @default(cuid())
  userId              String            @unique
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Public Profile Fields
  bio                 String?
  hourlyRate          Decimal?
  city                String?
  district            String?
  transportMode       String?           // e.g., "Car", "Public Transport", "Bike"
  
  // Stats & Status
  profileStatus       HelperStatus      @default(DRAFT)
  averageRating       Float             @default(0)
  reviewCount         Int               @default(0)
  isAcceptingRequests Boolean           @default(true)

  // Relations
  categories          HelperServiceCategory[]
  bookings            Booking[]
  verification        HelperVerification?

  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}

enum HelperStatus {
  DRAFT
  PENDING_VERIFICATION
  ACTIVE
  PAUSED
  REJECTED
}

model HelperServiceCategory {
  id              String        @id @default(cuid())
  helperProfileId String
  helperProfile   HelperProfile @relation(fields: [helperProfileId], references: [id])
  categorySlug    String        
  isActive        Boolean       @default(true)
}

// --- VERIFICATION ---

model HelperVerification {
  id                String             @id @default(cuid())
  helperProfileId   String             @unique
  helperProfile     HelperProfile      @relation(fields: [helperProfileId], references: [id])
  idDocumentStatus  VerificationStatus @default(NOT_STARTED)
  selfieStatus      VerificationStatus @default(NOT_STARTED)
  reviewedAt        DateTime?
  reviewNotes       String?
}

enum VerificationStatus {
  NOT_STARTED
  PENDING
  APPROVED
  REJECTED
  NEEDS_ACTION
}

// --- MARKETPLACE & BOOKINGS ---

model SupportRequest {
  id             String          @id @default(cuid())
  clientId       String
  client         ClientProfile   @relation(fields: [clientId], references: [id])
  categorySlug   String
  title          String
  description    String
  status         RequestStatus   @default(OPEN)
  requestedDate  DateTime
  city           String          @default("Berlin")
  district       String?
  
  // Relations
  bookings       Booking[]

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

enum RequestStatus {
  DRAFT
  OPEN
  MATCHED
  BOOKED
  CANCELED
  EXPIRED
}

model Booking {
  id                String          @id @default(cuid())
  requestId         String?
  request           SupportRequest? @relation(fields: [requestId], references: [id])
  clientId          String
  client            ClientProfile   @relation(fields: [clientId], references: [id])
  helperId          String
  helper            HelperProfile   @relation(fields: [helperId], references: [id])
  
  status            BookingStatus   @default(PENDING_ACCEPTANCE)
  scheduledDate     DateTime
  totalPrice        Decimal
  paymentStatus     PaymentStatus   @default(UNPAID)
  
  // Relations
  messages          Message[]
  reviews           Review[]
  reports           Report[]

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

enum BookingStatus {
  PENDING_ACCEPTANCE
  AWAITING_PAYMENT
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELED
  DISPUTED
}

enum PaymentStatus {
  UNPAID
  PAID
  FAILED
  REFUNDED
}

// --- COMMUNICATION & REVIEWS ---

model Message {
  id             String   @id @default(cuid())
  bookingId      String
  booking        Booking  @relation(fields: [bookingId], references: [id])
  senderId       String
  sender         User     @relation(fields: [senderId], references: [id])
  body           String
  readAt         DateTime?
  createdAt      DateTime @default(now())
}

model Review {
  id             String   @id @default(cuid())
  bookingId      String
  booking        Booking  @relation(fields: [bookingId], references: [id])
  reviewerId     String
  rating         Int
  comment        String?
  createdAt      DateTime @default(now())
}

// --- TRUST, SAFETY & ADMIN ---

model Report {
  id             String       @id @default(cuid())
  reporterId     String
  reporter       User         @relation("Reporter", fields: [reporterId], references: [id])
  reportedUserId String?
  reportedUser   User?        @relation("ReportedUser", fields: [reportedUserId], references: [id])
  bookingId      String?
  booking        Booking?     @relation(fields: [bookingId], references: [id])
  description    String
  status         ReportStatus @default(OPEN)
  
  createdAt      DateTime     @default(now())
}

enum ReportStatus {
  OPEN
  UNDER_REVIEW
  ACTION_TAKEN
  DISMISSED
}

model AdminAction {
  id          String   @id @default(cuid())
  adminId     String
  admin       User     @relation(fields: [adminId], references: [id])
  actionType  String
  notes       String?
  createdAt   DateTime @default(now())
}